# Oracle 数据库连接 URL
#
# 直连 (ezconnect):
#   DATABASE_URL=oracle://user:password@host:port/service_name
#
# TNS 别名（需 tnsnames.ora）:
#   DATABASE_URL=oracle://user:password@tns_alias
#
# ATP/TCPS（需 Oracle Wallet）:
#   DATABASE_URL=oracle://user:password@tns_alias?wallet=/path/to/wallet_dir
TNS_ADMIN=/Users/dqh/sync/source/rust/sqlx-oracle/wallet
DATABASE_URL=oracle://DINGHAN.DQH:Dinghan0406%40oracle1@manager_medium
export DBNAME="manager"
export DBUSER="DINGHAN.DQH"
export DBPASS="k6vT7Ts9CVRbK2y"